---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import ServiceCard from '../../components/services/ServiceCard.astro';
import CTASection from '../../components/home/CTASection.astro';
import { getCollection } from 'astro:content';

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="Servicios"
  description="Servicios de construcción profesional: remodelaciones, obra gruesa, terminaciones y ampliaciones. Mano de obra cualificada en Santiago de Chile."
>
  <section class="py-16 sm:py-20 bg-neutral-50 border-b border-neutral-200/60">
    <Container>
      <SectionHeading
        label="Nuestros servicios"
        title="Todo lo que tu proyecto necesita"
        description="Cubrimos cada etapa de la construcción con personal cualificado, equipado y supervisado. Desde la obra gruesa hasta la terminación final."
      />
    </Container>
  </section>

  <section class="py-section">
    <Container>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <ServiceCard
            title={service.data.title}
            description={service.data.description}
            icon={service.data.icon}
            slug={service.id}
            features={service.data.features}
          />
        ))}
      </div>
    </Container>
  </section>

  <CTASection />
</BaseLayout>

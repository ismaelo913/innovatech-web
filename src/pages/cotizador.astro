---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import CotizadorForm from '../components/cotizador/CotizadorForm.tsx';
---

<BaseLayout
  title="Cotizador"
  description="Cotiza tu proyecto de construcción con Innovatech. Remodelaciones, obra gruesa, terminaciones y ampliaciones en Santiago."
>
  <section class="py-16 sm:py-20 bg-neutral-50 border-b border-neutral-200/60">
    <Container>
      <div class="max-w-2xl mx-auto text-center">
        <span class="inline-block text-sm font-semibold tracking-widest uppercase text-primary-600 mb-4">
          Cotizador
        </span>
        <h1 class="text-3xl sm:text-4xl font-bold text-neutral-950 tracking-tight leading-tight mb-4">
          Cotiza tu proyecto en minutos
        </h1>
        <p class="text-lg text-neutral-600">
          Completar el formulario toma menos de 2 minutos. Te respondemos en menos de 24 horas.
        </p>
      </div>
    </Container>
  </section>

  <section class="py-section">
    <Container narrow>
      <CotizadorForm client:visible />
    </Container>
  </section>
</BaseLayout>

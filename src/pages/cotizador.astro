---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Button from '../components/ui/Button.astro';
import { SERVICES } from '../lib/constants';

const comunas = [
  'Santiago Centro', 'Providencia', 'Las Condes', 'Vitacura', 'Lo Barnechea',
  'Nunoa', 'La Reina', 'Macul', 'Penalolen', 'La Florida',
  'San Miguel', 'San Joaquin', 'Maipu', 'Pudahuel', 'Cerrillos',
  'Estacion Central', 'Quinta Normal', 'Recoleta', 'Independencia', 'Huechuraba',
  'Otra comuna',
];
---

<BaseLayout
  title="Cotizador"
  description="Cotiza tu proyecto de construcción con Innovatech. Remodelaciones, obra gruesa, terminaciones y ampliaciones en Santiago."
>
  <section class="py-16 sm:py-20 bg-neutral-50 border-b border-neutral-200/60">
    <Container>
      <div class="max-w-2xl mx-auto text-center">
        <span class="inline-block text-sm font-semibold tracking-widest uppercase text-primary-600 mb-4">
          Cotizador
        </span>
        <h1 class="text-3xl sm:text-4xl font-bold text-neutral-950 tracking-tight leading-tight mb-4">
          Cotiza tu proyecto en minutos
        </h1>
        <p class="text-lg text-neutral-600">
          Completar el formulario toma menos de 2 minutos. Te respondemos en menos de 24 horas.
        </p>
      </div>
    </Container>
  </section>

  <section class="py-section">
    <Container narrow>
      <form action="#" method="POST" class="space-y-10" id="cotizador-form">
        {/* Honeypot */}
        <div class="hidden" aria-hidden="true">
          <input type="text" name="_honey" tabindex="-1" autocomplete="off" />
        </div>

        {/* Step 1: Service */}
        <div>
          <h2 class="text-xl font-bold text-neutral-900 mb-1">1. Tipo de servicio</h2>
          <p class="text-sm text-neutral-500 mb-5">Selecciona el servicio que mejor se ajuste a tu necesidad.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {SERVICES.map((service, i) => (
              <label class="relative cursor-pointer">
                <input
                  type="radio"
                  name="service"
                  value={service.title}
                  required
                  class="peer sr-only"
                />
                <div class="p-4 rounded-xl border-2 border-neutral-200 bg-white hover:border-primary-300 peer-checked:border-primary-500 peer-checked:bg-primary-50 transition-all">
                  <div class="font-medium text-neutral-900 text-sm">{service.title}</div>
                  <div class="text-xs text-neutral-500 mt-1">{service.short}</div>
                </div>
              </label>
            ))}
          </div>
        </div>

        {/* Step 2: Details */}
        <div>
          <h2 class="text-xl font-bold text-neutral-900 mb-1">2. Detalles del proyecto</h2>
          <p class="text-sm text-neutral-500 mb-5">Cuéntanos un poco más sobre lo que necesitas.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="area" class="block text-sm font-medium text-neutral-700 mb-1.5">Metros cuadrados aproximados</label>
              <input
                type="number"
                id="area"
                name="area"
                min="1"
                required
                class="w-full px-4 py-2.5 rounded-lg border border-neutral-300 bg-white text-neutral-900 text-sm placeholder:text-neutral-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-colors outline-none"
                placeholder="Ej: 80"
              />
            </div>
            <div>
              <label for="comuna" class="block text-sm font-medium text-neutral-700 mb-1.5">Comuna</label>
              <select
                id="comuna"
                name="comuna"
                required
                class="w-full px-4 py-2.5 rounded-lg border border-neutral-300 bg-white text-neutral-900 text-sm focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-colors outline-none"
              >
                <option value="" disabled selected>Selecciona tu comuna</option>
                {comunas.map((c) => (
                  <option value={c}>{c}</option>
                ))}
              </select>
            </div>
          </div>
          <div class="mt-5">
            <label for="description" class="block text-sm font-medium text-neutral-700 mb-1.5">Descripción del proyecto</label>
            <textarea
              id="description"
              name="description"
              rows="3"
              class="w-full px-4 py-2.5 rounded-lg border border-neutral-300 bg-white text-neutral-900 text-sm placeholder:text-neutral-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-colors outline-none resize-y"
              placeholder="Describe brevemente lo que necesitas: tipo de trabajo, estado actual del espacio, requerimientos especiales..."
            ></textarea>
          </div>
          <div class="mt-5">
            <label for="urgency" class="block text-sm font-medium text-neutral-700 mb-1.5">Urgencia</label>
            <div class="flex flex-wrap gap-3">
              {['Flexible', '1-3 meses', 'Urgente'].map((u) => (
                <label class="cursor-pointer">
                  <input type="radio" name="urgency" value={u} class="peer sr-only" />
                  <span class="inline-flex px-4 py-2 rounded-lg border-2 border-neutral-200 text-sm font-medium text-neutral-700 hover:border-primary-300 peer-checked:border-primary-500 peer-checked:bg-primary-50 peer-checked:text-primary-700 transition-all">
                    {u}
                  </span>
                </label>
              ))}
            </div>
          </div>
        </div>

        {/* Step 3: Contact */}
        <div>
          <h2 class="text-xl font-bold text-neutral-900 mb-1">3. Datos de contacto</h2>
          <p class="text-sm text-neutral-500 mb-5">Para enviarte la cotización lo antes posible.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-sm font-medium text-neutral-700 mb-1.5">Nombre completo</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-2.5 rounded-lg border border-neutral-300 bg-white text-neutral-900 text-sm placeholder:text-neutral-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-colors outline-none"
                placeholder="Juan Perez"
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-neutral-700 mb-1.5">Teléfono</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                class="w-full px-4 py-2.5 rounded-lg border border-neutral-300 bg-white text-neutral-900 text-sm placeholder:text-neutral-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-colors outline-none"
                placeholder="+56 9 1234 5678"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-neutral-700 mb-1.5">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-2.5 rounded-lg border border-neutral-300 bg-white text-neutral-900 text-sm placeholder:text-neutral-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-colors outline-none"
                placeholder="juan@email.com"
              />
            </div>
            <div>
              <label for="contact-pref" class="block text-sm font-medium text-neutral-700 mb-1.5">Prefiero que me contacten por</label>
              <select
                id="contact-pref"
                name="contact_preference"
                class="w-full px-4 py-2.5 rounded-lg border border-neutral-300 bg-white text-neutral-900 text-sm focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-colors outline-none"
              >
                <option value="whatsapp">WhatsApp</option>
                <option value="llamada">Llamada telefónica</option>
                <option value="email">Email</option>
              </select>
            </div>
          </div>
        </div>

        {/* Submit */}
        <div class="pt-4 border-t border-neutral-200">
          <Button variant="accent" size="lg" class="w-full sm:w-auto">
            Enviar solicitud de cotización
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
            </svg>
          </Button>
          <p class="text-xs text-neutral-500 mt-3">
            Al enviar este formulario aceptas que te contactemos para darte una cotización. No compartimos tus datos.
          </p>
        </div>
      </form>
    </Container>
  </section>
</BaseLayout>

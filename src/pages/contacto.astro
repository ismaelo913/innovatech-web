---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import ContactForm from '../components/contact/ContactForm.tsx';
import { SITE } from '../lib/constants';
import { whatsappUrl } from '../lib/utils';

const contactInfo = [
  {
    label: 'Teléfono',
    value: SITE.phone,
    href: `tel:${SITE.phone}`,
    icon: 'M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z',
  },
  {
    label: 'Email',
    value: SITE.email,
    href: `mailto:${SITE.email}`,
    icon: 'M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75',
  },
  {
    label: 'Dirección',
    value: SITE.address,
    href: '#mapa',
    icon: 'M15 10.5a3 3 0 11-6 0 3 3 0 016 0z M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z',
  },
  {
    label: 'Horario',
    value: 'Lunes a Viernes, 08:00 - 18:00',
    href: null,
    icon: 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z',
  },
];
---

<BaseLayout
  title="Contacto"
  description="Contacta a Innovatech para cotizar tu proyecto de construcción en Santiago. Formulario, teléfono, email y WhatsApp."
>
  {/* Hero */}
  <section class="py-16 sm:py-20 bg-neutral-50 border-b border-neutral-200/60">
    <Container>
      <div class="max-w-3xl mx-auto text-center">
        <span class="inline-block text-sm font-semibold tracking-widest uppercase text-primary-600 mb-4">
          Contacto
        </span>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-neutral-950 tracking-tight leading-tight mb-6">
          Conversemos sobre tu proyecto
        </h1>
        <p class="text-lg text-neutral-600 leading-relaxed">
          Cuéntanos qué necesitas y te respondemos en menos de 24 horas. Sin compromiso, sin letra chica.
        </p>
      </div>
    </Container>
  </section>

  {/* Contact form + info */}
  <section class="py-section">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
        {/* Form — React Island */}
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-bold text-neutral-900 mb-6">Enviar mensaje</h2>
          <ContactForm client:visible />
        </div>

        {/* Contact info */}
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-neutral-900 mb-6">Información de contacto</h2>
          <div class="space-y-5 mb-8">
            {contactInfo.map((info) => (
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-primary-50 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={info.icon} />
                  </svg>
                </div>
                <div>
                  <div class="text-sm font-medium text-neutral-500">{info.label}</div>
                  {info.href ? (
                    <a href={info.href} class="text-neutral-900 hover:text-primary-600 transition-colors">
                      {info.value}
                    </a>
                  ) : (
                    <span class="text-neutral-900">{info.value}</span>
                  )}
                </div>
              </div>
            ))}
          </div>

          {/* WhatsApp CTA */}
          <div class="p-6 rounded-xl bg-green-50 border border-green-200">
            <h3 class="font-semibold text-green-900 mb-2">Respuesta rápida por WhatsApp</h3>
            <p class="text-sm text-green-700 mb-4">Escríbenos directamente y te respondemos al instante.</p>
            <a
              href={whatsappUrl(SITE.whatsapp, 'Hola, quiero consultar sobre un proyecto de construcción.')}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[#25D366] text-white font-medium text-sm hover:bg-[#1fb855] transition-colors"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Abrir WhatsApp
            </a>
          </div>
        </div>
      </div>
    </Container>
  </section>

  {/* Map */}
  <section id="mapa" class="border-t border-neutral-200/60">
    <div class="aspect-[21/9] bg-neutral-200 flex items-center justify-center">
      <div class="text-center p-8">
        <svg class="w-12 h-12 text-neutral-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
        </svg>
        <p class="text-neutral-500 font-medium">Mapa de Google Maps</p>
        <p class="text-sm text-neutral-400">Se integrará con la dirección real de Innovatech</p>
      </div>
    </div>
  </section>
</BaseLayout>

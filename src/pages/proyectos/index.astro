---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import Badge from '../../components/ui/Badge.astro';
import CTASection from '../../components/home/CTASection.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const projectImages: Record<string, string> = {
  'oficinas-las-condes': '/images/projects/terminaciones-interior.jpeg',
  'edificio-nunoa': '/images/projects/estructura-metalica-1.jpeg',
  'ampliacion-providencia': '/images/projects/estructura-metalica-2.jpeg',
};

const categoryLabels: Record<string, string> = {
  'remodelacion-residencial': 'Remodelacion Residencial',
  'remodelacion-comercial': 'Remodelacion Comercial',
  'obra-gruesa': 'Obra Gruesa',
  'terminaciones': 'Terminaciones',
  'ampliacion': 'Ampliacion',
};
---

<BaseLayout
  title="Proyectos"
  description="Portafolio de proyectos de construccion ejecutados por Innovatech en Santiago. Remodelaciones, obra gruesa, terminaciones y ampliaciones."
>
  <section class="py-16 sm:py-20 bg-neutral-50 border-b border-neutral-200/60">
    <Container>
      <SectionHeading
        label="Portafolio"
        title="Proyectos ejecutados"
        description="Cada proyecto refleja nuestro compromiso con la calidad, los plazos y la seguridad. Estos son algunos de nuestros trabajos."
      />
    </Container>
  </section>

  <section class="py-section">
    <Container>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project) => (
          <a href={`/proyectos/${project.id}`} class="group block">
            <div class="rounded-xl overflow-hidden border border-neutral-200/60 bg-white shadow-sm transition-all duration-300 group-hover:shadow-lg group-hover:-translate-y-0.5">
              <div class="aspect-[4/3] relative overflow-hidden bg-neutral-200">
                <img
                  src={projectImages[project.id] || '/images/projects/estructura-metalica-1.jpeg'}
                  alt={project.data.title}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-primary-600/0 group-hover:bg-primary-600/10 transition-colors duration-300"></div>
              </div>
              <div class="p-5">
                <Badge variant="primary" class="mb-3">
                  {categoryLabels[project.data.category]}
                </Badge>
                <h3 class="text-lg font-semibold text-neutral-900 mb-2 group-hover:text-primary-600 transition-colors">
                  {project.data.title}
                </h3>
                <div class="flex items-center flex-wrap gap-x-4 gap-y-1 text-sm text-neutral-500">
                  <span class="flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                    </svg>
                    {project.data.location}
                  </span>
                  <span>{project.data.area}</span>
                  <span>{project.data.duration}</span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <CTASection />
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import ProjectFilter from '../../components/projects/ProjectFilter.tsx';
import CTASection from '../../components/home/CTASection.astro';
import { getCollection } from 'astro:content';

const rawProjects = (await getCollection('projects')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const projectImages: Record<string, string> = {
  'condominio-colina': '/images/projects/colina-1.jpeg',
  'condominio-las-condes': '/images/projects/las-condes-1.jpeg',
  'techumbre-terminaciones': '/images/projects/techumbre-1.jpeg',
};

const categoryLabels: Record<string, string> = {
  'remodelacion-residencial': 'Remodelación Residencial',
  'remodelacion-comercial': 'Remodelación Comercial',
  'obra-gruesa': 'Obra Gruesa',
  'terminaciones': 'Terminaciones',
  'ampliacion': 'Ampliación',
};

// Serialize projects for the React island
const projects = rawProjects.map((p) => ({
  id: p.id,
  title: p.data.title,
  category: p.data.category,
  location: p.data.location || undefined,
  image: projectImages[p.id] || '/images/projects/colina-1.jpeg',
}));
---

<BaseLayout
  title="Proyectos"
  description="Proyectos de construcción ejecutados por Innovatech en Santiago. Calidad que se ve, seguridad que se siente."
>
  <section class="py-16 sm:py-20 bg-neutral-50 border-b border-neutral-200/60">
    <Container>
      <SectionHeading
        label="Portafolio"
        title="Proyectos que reflejan nuestro compromiso"
        description="Cada obra es una oportunidad de demostrar que la calidad y la seguridad hacen la diferencia."
      />
    </Container>
  </section>

  <section class="py-section">
    <Container>
      <ProjectFilter client:load projects={projects} categoryLabels={categoryLabels} />
    </Container>
  </section>

  <CTASection />
</BaseLayout>

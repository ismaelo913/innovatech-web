---
interface Props {
  hover?: boolean;
  padding?: 'none' | 'sm' | 'md' | 'lg';
  class?: string;
}

const { hover = true, padding = 'md', class: className } = Astro.props;

const paddings: Record<string, string> = {
  none: '',
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
};
---

<div
  class:list={[
    'bg-white rounded-xl border border-neutral-200/60 shadow-sm',
    hover && 'transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5',
    paddings[padding],
    className,
  ]}
>
  <slot />
</div>

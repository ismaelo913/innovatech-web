---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import Badge from '../ui/Badge.astro';
---

<section class="relative overflow-hidden py-20 sm:py-28 lg:py-36">
  <!-- Background decoration -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-primary-100/40 rounded-full blur-3xl -translate-y-1/2 translate-x-1/4"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-accent-100/30 rounded-full blur-3xl translate-y-1/2 -translate-x-1/4"></div>
    <!-- Grid pattern -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,theme(--color-neutral-200)_1px,transparent_1px),linear-gradient(to_bottom,theme(--color-neutral-200)_1px,transparent_1px)] bg-[size:4rem_4rem] opacity-30"></div>
  </div>

  <Container>
    <div class="max-w-4xl mx-auto text-center">
      <Badge variant="primary" class="mb-6">
        Startup de construcción en Santiago
      </Badge>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-neutral-950 leading-[1.1] mb-6">
        Construcción profesional
        <span class="relative inline-block">
          <span class="relative z-10 text-primary-600">sin improvisación</span>
          <span class="absolute bottom-1 left-0 w-full h-3 bg-primary-200/60 -z-0 rounded"></span>
        </span>
      </h1>

      <p class="text-lg sm:text-xl text-neutral-600 max-w-2xl mx-auto mb-10 leading-relaxed">
        Somos el subcontratista que tu proyecto necesita. Mano de obra cualificada, equipada con EPPs y herramientas, bajo supervisión permanente. Desde remodelaciones hasta obra gruesa.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/cotizador" size="lg" variant="accent">
          Cotiza tu proyecto
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </Button>
        <Button href="/servicios" size="lg" variant="outline">
          Conoce nuestros servicios
        </Button>
      </div>

      <!-- Trust indicators -->
      <div class="mt-16 flex flex-wrap items-center justify-center gap-x-8 gap-y-4 text-sm text-neutral-500">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          Personal con EPPs
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          Supervisión permanente
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          Herramientas propias
        </div>
      </div>
    </div>
  </Container>
</section>

---
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';

const projects = [
  {
    title: 'Remodelacion Oficinas Corporativas',
    category: 'Remodelacion Comercial',
    location: 'Las Condes, Santiago',
    area: '450 m2',
    image: '/images/project-placeholder-1.jpg',
    slug: 'oficinas-corporativas-las-condes',
  },
  {
    title: 'Obra Gruesa Edificio Residencial',
    category: 'Obra Gruesa',
    location: 'Nunoa, Santiago',
    area: '1.200 m2',
    image: '/images/project-placeholder-2.jpg',
    slug: 'edificio-residencial-nunoa',
  },
  {
    title: 'Ampliacion Vivienda Familiar',
    category: 'Ampliacion',
    location: 'Providencia, Santiago',
    area: '85 m2',
    image: '/images/project-placeholder-3.jpg',
    slug: 'ampliacion-vivienda-providencia',
  },
];
---

<section class="py-section">
  <Container>
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12">
      <SectionHeading
        label="Proyectos"
        title="Trabajos que hablan por si solos"
        description="Cada proyecto refleja nuestro compromiso con la calidad, los plazos y la seguridad."
        align="left"
        class="mb-0"
      />
      <Button href="/proyectos" variant="outline" size="sm" class="shrink-0 self-start sm:self-auto">
        Ver todos los proyectos
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </Button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <a href={`/proyectos/${project.slug}`} class="group block">
          <div class="rounded-xl overflow-hidden border border-neutral-200/60 bg-white shadow-sm transition-all duration-300 group-hover:shadow-lg group-hover:-translate-y-0.5">
            {/* Image placeholder */}
            <div class="aspect-[4/3] bg-neutral-200 relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-br from-primary-100 to-primary-200 flex items-center justify-center">
                <svg class="w-12 h-12 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a2.25 2.25 0 002.25-2.25V5.25a2.25 2.25 0 00-2.25-2.25H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
                </svg>
              </div>
              {/* Hover overlay */}
              <div class="absolute inset-0 bg-primary-600/0 group-hover:bg-primary-600/10 transition-colors duration-300"></div>
            </div>

            <div class="p-5">
              <Badge variant="primary" class="mb-3">{project.category}</Badge>
              <h3 class="text-lg font-semibold text-neutral-900 mb-2 group-hover:text-primary-600 transition-colors">
                {project.title}
              </h3>
              <div class="flex items-center gap-4 text-sm text-neutral-500">
                <span class="flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                  {project.location}
                </span>
                <span class="flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />
                  </svg>
                  {project.area}
                </span>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </Container>
</section>

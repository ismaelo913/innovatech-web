---
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';

const projects = [
  {
    title: 'Condominio Colina',
    category: 'Terminaciones',
    location: 'Colina, Santa Elena',
    image: '/images/projects/colina-1.jpeg',
    slug: 'condominio-colina',
  },
  {
    title: 'Condominio Las Condes',
    category: 'Terminaciones',
    location: 'Las Condes, Santiago',
    image: '/images/projects/las-condes-1.jpeg',
    slug: 'condominio-las-condes',
  },
  {
    title: 'Techumbre y Terminaciones',
    category: 'Terminaciones',
    location: null,
    image: '/images/projects/techumbre-1.jpeg',
    slug: 'techumbre-terminaciones',
  },
];
---

<section class="py-section">
  <Container>
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12">
      <SectionHeading
        label="Proyectos"
        title="Trabajos que hablan por si solos"
        description="Cada proyecto refleja nuestro compromiso con la calidad, los plazos y la seguridad."
        align="left"
        class="mb-0"
      />
      <Button href="/proyectos" variant="outline" size="sm" class="shrink-0 self-start sm:self-auto">
        Ver todos los proyectos
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </Button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <a href={`/proyectos/${project.slug}`} class="group block">
          <div class="rounded-xl overflow-hidden border border-neutral-200/60 bg-white shadow-sm transition-all duration-300 group-hover:shadow-lg group-hover:-translate-y-0.5">
            <div class="aspect-[4/3] bg-neutral-200 relative overflow-hidden">
              <img
                src={project.image}
                alt={project.title}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-primary-600/0 group-hover:bg-primary-600/10 transition-colors duration-300"></div>
            </div>

            <div class="p-5">
              <Badge variant="primary" class="mb-3">{project.category}</Badge>
              <h3 class="text-lg font-semibold text-neutral-900 mb-2 group-hover:text-primary-600 transition-colors">
                {project.title}
              </h3>
              <div class="flex items-center gap-4 text-sm text-neutral-500">
                {project.location && (
                  <span class="flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                    </svg>
                    {project.location}
                  </span>
                )}
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </Container>
</section>
